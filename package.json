{
    "name": "agent-room-monorepo",
    "private": true,
    "license": "MIT",
    "author": "Parsa Lalianpour",
    "description": "Agent Room OSS workspace for the self-hosted product, marketing shell, shared brand package, and infra.",
    "keywords": [
        "agents",
        "ai",
        "orchestration",
        "self-hosted",
        "automation"
    ],
    "type": "module",
    "packageManager": "bun@1.3.13",
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/parlali/agent_room.git"
    },
    "bugs": {
        "url": "https://github.com/parlali/agent_room/issues"
    },
    "homepage": "https://github.com/parlali/agent_room#readme",
    "scripts": {
        "dev": "turbo run dev --parallel",
        "build": "turbo run build",
        "start": "bun run --filter @agent-room/self-hosted start",
        "preview": "bun run --filter @agent-room/self-hosted preview",
        "test": "turbo run test",
        "typecheck": "turbo run typecheck",
        "lint": "turbo run lint",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "check": "bun run format && turbo run lint typecheck test",
        "fix": "bun run format:write",
        "quality:score": "bun run --filter @agent-room/self-hosted quality:score",
        "db:generate": "bun run --filter @agent-room/self-hosted db:generate",
        "db:migrate": "bun run --filter @agent-room/self-hosted db:migrate",
        "bootstrap:root": "bun run --filter @agent-room/self-hosted bootstrap:root",
        "self-hosted:dev": "bun run --filter @agent-room/self-hosted dev",
        "self-hosted:build": "bun run --filter @agent-room/self-hosted build",
        "self-hosted:cloudflare:build": "bun run --filter @agent-room/self-hosted build:cloudflare",
        "self-hosted:cloudflare:deploy": "bun run --filter @agent-room/self-hosted deploy:cloudflare",
        "self-hosted:cloudflare:deploy:built": "bun run --filter @agent-room/self-hosted deploy:cloudflare:built",
        "self-hosted:cloudflare:secrets": "bun run --filter @agent-room/self-hosted secrets:cloudflare",
        "self-hosted:cloudflare:typegen": "bun run --filter @agent-room/self-hosted types:cloudflare",
        "self-hosted:cloudflare:d1:migrate": "bun run --filter @agent-room/self-hosted d1:migrate:cloudflare",
        "self-hosted:start": "bun run --filter @agent-room/self-hosted start",
        "self-hosted:preview": "bun run --filter @agent-room/self-hosted preview",
        "marketing:dev": "bun run --filter @agent-room/marketing dev",
        "marketing:build": "bun run --filter @agent-room/marketing build",
        "marketing:preview": "bun run --filter @agent-room/marketing preview",
        "marketing:start": "bun run --filter @agent-room/marketing start",
        "marketing:typecheck": "bun run --filter @agent-room/marketing typecheck",
        "marketing:deploy": "bun run apps/marketing/scripts/deploy-cloudflare.ts",
        "marketing:d1:migrate": "bun run apps/marketing/scripts/deploy-cloudflare.ts --migrate-only",
        "marketing:d1:migrate:local": "bun x wrangler d1 migrations apply agent-room-marketing-waitlist --local",
        "brand:export": "bun run --filter @agent-room/brand export:icons",
        "brand:export:marketing": "bun run --filter @agent-room/brand export:marketing"
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260610.1",
        "@tanstack/eslint-config": "0.4.0",
        "eslint": "^10.4.0",
        "prettier": "^3.8.1",
        "turbo": "^2.9.14",
        "wrangler": "^4.99.0"
    }
}
