FROM oven/bun:1.3.13 AS builder

WORKDIR /app/apps/self-hosted

COPY apps/self-hosted/package.runtime.json package.json
RUN bun install --production

COPY apps/self-hosted/src src
COPY apps/self-hosted/scripts/copy-runtime-assets.ts scripts/copy-runtime-assets.ts
COPY apps/self-hosted/scripts/build-runtime-bundle.ts scripts/build-runtime-bundle.ts
COPY apps/self-hosted/tsconfig.json tsconfig.json
RUN bun run scripts/copy-runtime-assets.ts \
    && bun run scripts/build-runtime-bundle.ts \
    && chmod -R go-rX src \
    && chmod -R a+rX dist/server/assets/skills dist/runtime


FROM oven/bun:1.3.13

WORKDIR /app

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        bash \
        bzip2 \
        ca-certificates \
        file \
        fonts-dejavu \
        gh \
        git \
        jq \
        less \
        make \
        openssh-client \
        passwd \
        patch \
        python3 \
        python3-venv \
        ripgrep \
        rsync \
        sqlite3 \
        tini \
        tree \
        unzip \
        util-linux \
        xz-utils \
        zip \
        zstd \
    && ln -sf /usr/bin/python3 /usr/local/bin/python \
    && rm -f /usr/bin/apt /usr/bin/apt-get /usr/bin/apt-cache \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/apps/self-hosted/package.json apps/self-hosted/package.json
COPY --from=builder /app/apps/self-hosted/tsconfig.json apps/self-hosted/tsconfig.json
COPY --from=builder /app/apps/self-hosted/node_modules apps/self-hosted/node_modules
COPY --from=builder /app/apps/self-hosted/src apps/self-hosted/src
COPY --from=builder /app/apps/self-hosted/dist apps/self-hosted/dist

RUN groupadd --system agentroom \
    && useradd --system --gid agentroom --home-dir /workspace --create-home agentroom \
    && mkdir -p /workspace/.agent-room \
    && chown -R agentroom:agentroom /workspace apps/self-hosted/src apps/self-hosted/dist

WORKDIR /app/apps/self-hosted

ENV NODE_ENV=production
ENV PORT=3000
ENV AGENT_ROOM_DATA_DIR=/workspace/.agent-room

EXPOSE 3000

USER agentroom

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["bun", "--no-env-file", "run", "dist/runtime/main.js"]
