# Docker Compose settings.
AGENT_ROOM_PORT=3000
AGENT_ROOM_POSTGRES_PASSWORD=agent_room
AGENT_ROOM_SEARXNG_TAG=2026.5.2-aefc3c316

# Optional first-boot overrides. If omitted, Agent Room generates and persists bootstrap state.
# AGENT_ROOM_ENCRYPTION_KEY_B64=
# AGENT_ROOM_ROOT_EMAIL=
# AGENT_ROOM_ROOT_PASSWORD=
# AGENT_ROOM_SESSION_TTL_HOURS=24
# AGENT_ROOM_BROWSER_ACTIONS_PER_TURN=50

# Runtime sandbox hardening. Limits apply to the agent's sandboxed (per-room) tool
# processes. Core dumps are always disabled. A value of 0 disables a numeric limit.
# Defaults are non-breaking for self-hosted; hosted multi-tenant deployments should
# tighten these and enable restricted egress.
# AGENT_ROOM_RUNTIME_MAX_PROCESSES=8192
# AGENT_ROOM_RUNTIME_MAX_OPEN_FILES=
# AGENT_ROOM_RUNTIME_MAX_FILE_SIZE_BYTES=
# AGENT_ROOM_RUNTIME_MAX_CPU_SECONDS=
# AGENT_ROOM_RUNTIME_MAX_ADDRESS_SPACE_BYTES=
# When true, managed HTTP MCP servers may not target localhost, private, or metadata
# addresses. Leave false for self-hosted setups that run MCP servers on localhost.
# AGENT_ROOM_RUNTIME_RESTRICT_PRIVATE_NETWORK=false

# Local host development only.
# NODE_ENV=development
# PORT=3000
# DATABASE_URL=postgres://agent_room:agent_room@127.0.0.1:5432/agent_room?sslmode=disable
# AGENT_ROOM_DATA_DIR=.agent-room
