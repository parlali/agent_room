{
    "extends": "@agent-room/typescript-config/vite-react",
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "#/*": ["./src/*"],
            "@/*": ["./src/*"]
        },
        "types": ["vite/client", "node"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "scripts/**/*.ts",
        "vite.config.ts",
        "drizzle.config.ts"
    ]
}
