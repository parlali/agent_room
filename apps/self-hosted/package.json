{
    "name": "@agent-room/self-hosted",
    "private": true,
    "license": "MIT",
    "author": "Parsa Lalianpour",
    "description": "Self-hosted Agent Room product app and runtime.",
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build && bun run scripts/copy-runtime-assets.ts",
        "build:cloudflare": "AGENT_ROOM_DEPLOY_TARGET=cloudflare vite build && bun run scripts/copy-runtime-assets.ts",
        "start": "bun run scripts/start-server.ts",
        "preview": "vite preview",
        "preview:cloudflare": "AGENT_ROOM_DEPLOY_TARGET=cloudflare vite preview",
        "deploy:cloudflare": "bun run build:cloudflare && wrangler deploy --config dist/server/wrangler.json",
        "secrets:cloudflare": "bun run scripts/cloudflare-put-secrets.ts",
        "types:cloudflare": "wrangler types --config wrangler.hosted.jsonc --include-runtime false",
        "test": "vitest run",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "check": "bun run format && bun run lint && bun run typecheck && bun run test",
        "fix": "bun run format:write",
        "quality:score": "bun run scripts/code-quality-score.ts",
        "db:migrate": "bun run scripts/dbmate.ts up",
        "db:rollback": "bun run scripts/dbmate.ts down",
        "db:new": "bun run scripts/dbmate.ts new",
        "d1:migrate:cloudflare": "wrangler d1 migrations apply agent-room-hosted --remote --config wrangler.hosted.jsonc",
        "bootstrap:root": "bun run scripts/bootstrap-root-user.ts"
    },
    "dependencies": {
        "@agent-room/brand": "workspace:*",
        "@cloudflare/containers": "^0.3.7",
        "@fontsource-variable/geist": "^5.2.8",
        "@mariozechner/pi-ai": "0.70.6",
        "@mariozechner/pi-coding-agent": "0.70.6",
        "@modelcontextprotocol/sdk": "1.29.0",
        "@tailwindcss/vite": "^4.1.18",
        "@tanstack/react-devtools": "0.10.2",
        "@tanstack/react-query": "5.99.2",
        "@tanstack/react-router": "1.168.23",
        "@tanstack/react-router-devtools": "1.166.13",
        "@tanstack/react-start": "1.167.42",
        "@tanstack/react-virtual": "^3.13.24",
        "@tanstack/router-plugin": "1.167.22",
        "@xmldom/xmldom": "^0.9.10",
        "better-auth": "^1.6.19",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "cookie": "^1.0.2",
        "jszip": "^3.10.1",
        "lucide-react": "^1.8.0",
        "next-themes": "^0.4.6",
        "pdf-lib": "^1.17.1",
        "postgres": "^3.4.7",
        "radix-ui": "^1.4.3",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "react-markdown": "^10.1.0",
        "remark-gfm": "^4.0.1",
        "remend": "^1.3.0",
        "shadcn": "^4.3.1",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.1.18",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.1.12"
    },
    "devDependencies": {
        "@agent-room/typescript-config": "workspace:*",
        "@cloudflare/vite-plugin": "^1.42.1",
        "@tanstack/devtools-vite": "0.6.0",
        "@tanstack/eslint-config": "0.4.0",
        "@types/node": "^22.10.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "prettier": "^3.8.1",
        "typescript": "^5.7.2",
        "vite": "^8.0.0",
        "vitest": "^3.0.5"
    }
}
