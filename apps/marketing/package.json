{
    "name": "@agent-room/marketing",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "description": "Public marketing site for Agent Room.",
    "scripts": {
        "dev": "bun --bun vite",
        "build": "bun --bun vite build",
        "preview": "bun run server/serve.ts",
        "start": "bun run server/serve.ts",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "format": "prettier --check .",
        "format:write": "prettier --write .",
        "check": "bun run format && bun run lint && bun run typecheck && bun run build"
    },
    "dependencies": {
        "@agent-room/brand": "workspace:*",
        "@fontsource-variable/geist": "^5.2.8",
        "@fontsource-variable/jetbrains-mono": "^5.2.5",
        "@radix-ui/react-accordion": "^1.2.13",
        "react": "^19.2.0",
        "react-dom": "^19.2.0"
    },
    "devDependencies": {
        "@agent-room/typescript-config": "workspace:*",
        "bun-types": "^1.3.13",
        "@tailwindcss/vite": "^4.1.18",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.1",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.7.2",
        "vite": "^8.0.0"
    }
}
